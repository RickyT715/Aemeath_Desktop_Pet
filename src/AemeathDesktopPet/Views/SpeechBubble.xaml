<UserControl x:Class="AemeathDesktopPet.Views.SpeechBubble"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MaxWidth="260" MinWidth="80">

    <Border x:Name="BubbleBorder"
            Background="#EBF5F0F0"
            BorderBrush="{StaticResource DigitalBlueBrush}"
            BorderThickness="2"
            CornerRadius="12"
            Padding="12,8"
            >
        <Border.Effect>
            <DropShadowEffect Color="#5CB8E6" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
        </Border.Effect>

        <Grid>
            <!-- Paper plane watermark top-right -->
            <TextBlock Text="&#x2708;" FontSize="16" Opacity="0.12"
                       HorizontalAlignment="Right" VerticalAlignment="Top"
                       Margin="0,-2,-4,0" Foreground="{StaticResource DigitalBlueBrush}"/>

            <!-- Scanline overlay -->
            <Rectangle Opacity="0.02" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <DrawingBrush TileMode="Tile" Viewport="0,0,1,4" ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <GeometryDrawing Brush="#40000000">
                                <GeometryDrawing.Geometry>
                                    <RectangleGeometry Rect="0,0,1,2"/>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Message text -->
            <TextBlock x:Name="MessageText"
                       TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="#2D2D3D"
                       FontFamily="Segoe UI"
                       LineHeight="18"/>
        </Grid>
    </Border>
</UserControl>
