<Window x:Class="AemeathDesktopPet.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aemeath Settings"
        Width="520" Height="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource DarkSlateBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="10,10,10,0">

            <!-- General Tab -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <TextBlock Text="General" FontWeight="Bold" FontSize="16"
                                   Foreground="{StaticResource PrimaryPinkBrush}" Margin="0,0,0,12"/>

                        <CheckBox x:Name="StartWithWindowsCheck"
                                  Content="Start with Windows"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>

                        <CheckBox x:Name="CloseToTrayCheck"
                                  Content="Close to system tray instead of quitting"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>

                        <Rectangle Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,4,0,12"/>
                        <TextBlock Text="Companion Apps" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource DigitalBlueBrush}" Margin="0,0,0,6"/>
                        <TextBlock Text="Automatically launch companion programs when the pet starts."
                                   Foreground="#888" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"/>

                        <CheckBox x:Name="LaunchMonitorCheck"
                                  Content="Launch Computer &amp; Chrome Monitor on startup"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                        <DockPanel Margin="20,0,0,8">
                            <Button DockPanel.Dock="Right" Content="Browse..." Click="BrowseMonitorPath_Click"
                                    Padding="12,4" Margin="8,0,0,0"/>
                            <TextBox x:Name="MonitorPathBox"
                                     Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3"/>
                        </DockPanel>

                        <CheckBox x:Name="LaunchTodoCheck"
                                  Content="Launch To-Do List / Pomodoro Timer on startup"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                        <DockPanel Margin="20,0,0,8">
                            <Button DockPanel.Dock="Right" Content="Browse..." Click="BrowseTodoPath_Click"
                                    Padding="12,4" Margin="8,0,0,0"/>
                            <TextBox x:Name="TodoPathBox"
                                     Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3"/>
                        </DockPanel>

                        <StackPanel Margin="0,0,0,0">
                            <TextBlock Text="Behavior Frequency" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="BehaviorFreqCombo" Width="140" HorizontalAlignment="Left">
                                <ComboBoxItem Content="Calm" Tag="calm"/>
                                <ComboBoxItem Content="Normal" Tag="normal"/>
                                <ComboBoxItem Content="Active" Tag="active"/>
                            </ComboBox>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,12,0,12"/>
                        <TextBlock Text="Integrations" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource DigitalBlueBrush}" Margin="0,0,0,6"/>
                        <CheckBox x:Name="EnablePomodoroIntegrationCheck"
                                  Content="Connect to To-Do List / Pomodoro Timer"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="Aemeath will react to pomodoro timer events and new tasks. Requires app restart."
                                   Foreground="#888" FontSize="11" Margin="20,0,0,0" TextWrapping="Wrap"/>

                        <StackPanel x:Name="PomodoroPromptsPanel" Margin="20,8,0,0">
                            <TextBlock Text="LLM Prompt Templates" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{StaticResource DigitalBlueBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="Customize what Aemeath says for each event. Placeholders: {taskTitle}, {duration}, {breakType}"
                                       Foreground="#888" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <TextBlock Text="Work Started" Foreground="{StaticResource TextBrush}" FontSize="12" Margin="0,0,0,2"/>
                            <TextBox x:Name="PomoWorkStartedPromptBox" AcceptsReturn="True" TextWrapping="Wrap" Height="52"
                                     Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3" Margin="0,0,0,8"/>

                            <TextBlock Text="Work Finished" Foreground="{StaticResource TextBrush}" FontSize="12" Margin="0,0,0,2"/>
                            <TextBox x:Name="PomoWorkFinishedPromptBox" AcceptsReturn="True" TextWrapping="Wrap" Height="52"
                                     Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3" Margin="0,0,0,8"/>

                            <TextBlock Text="Break Started" Foreground="{StaticResource TextBrush}" FontSize="12" Margin="0,0,0,2"/>
                            <TextBox x:Name="PomoBreakStartedPromptBox" AcceptsReturn="True" TextWrapping="Wrap" Height="52"
                                     Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3" Margin="0,0,0,8"/>

                            <TextBlock Text="Break Finished" Foreground="{StaticResource TextBrush}" FontSize="12" Margin="0,0,0,2"/>
                            <TextBox x:Name="PomoBreakFinishedPromptBox" AcceptsReturn="True" TextWrapping="Wrap" Height="52"
                                     Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3" Margin="0,0,0,8"/>

                            <TextBlock Text="Task Added" Foreground="{StaticResource TextBrush}" FontSize="12" Margin="0,0,0,2"/>
                            <TextBox x:Name="PomoTaskAddedPromptBox" AcceptsReturn="True" TextWrapping="Wrap" Height="52"
                                     Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3" Margin="0,0,0,8"/>

                            <Button Content="Reset to Defaults" Click="ResetPomoPrompts_Click"
                                    HorizontalAlignment="Left" Padding="12,4"/>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,12,0,12"/>
                        <TextBlock Text="Activity Monitor" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource DigitalBlueBrush}" Margin="0,0,0,6"/>
                        <CheckBox x:Name="EnableActivityMonitorCheck"
                                  Content="Include recent activity in Aemeath's speech"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"
                                  Checked="ActivityMonitorToggled" Unchecked="ActivityMonitorToggled"/>
                        <TextBlock Text="When enabled and an AI provider is configured, Aemeath's idle chatter and pomodoro reactions will reference your recent computer activity."
                                   Foreground="#888" FontSize="11" Margin="20,0,0,8" TextWrapping="Wrap"/>

                        <StackPanel x:Name="ActivityMonitorPanel" Margin="20,0,0,0">
                            <TextBlock Text="Database Path" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="Browse..." Click="BrowseActivityDb_Click"
                                        Padding="12,4" Margin="8,0,0,0"/>
                                <TextBox x:Name="ActivityDbPathBox"
                                         Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                         BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3"/>
                            </DockPanel>
                            <TextBlock Text="Path to the SQLite database from Computer &amp; Chrome Monitor."
                                       Foreground="#888" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,12,0,12"/>
                        <TextBlock Text="Speech Frequency" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource DigitalBlueBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="Control how often Aemeath speaks during different activities. Gaming/Videos/Study detection requires Activity Monitor enabled."
                                   Foreground="#888" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"/>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Pomodoro Work" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,0,6"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" x:Name="FreqPomodoroWorkCombo" Width="120" HorizontalAlignment="Left" Margin="0,0,0,6">
                                <ComboBoxItem Content="Silent" Tag="Silent"/>
                                <ComboBoxItem Content="Rare" Tag="Rare"/>
                                <ComboBoxItem Content="Normal" Tag="Normal"/>
                                <ComboBoxItem Content="Chatty" Tag="Chatty"/>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Pomodoro Break" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,0,6"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="FreqPomodoroBreakCombo" Width="120" HorizontalAlignment="Left" Margin="0,0,0,6">
                                <ComboBoxItem Content="Silent" Tag="Silent"/>
                                <ComboBoxItem Content="Rare" Tag="Rare"/>
                                <ComboBoxItem Content="Normal" Tag="Normal"/>
                                <ComboBoxItem Content="Chatty" Tag="Chatty"/>
                            </ComboBox>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Gaming" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,0,6"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" x:Name="FreqGamingCombo" Width="120" HorizontalAlignment="Left" Margin="0,0,0,6">
                                <ComboBoxItem Content="Silent" Tag="Silent"/>
                                <ComboBoxItem Content="Rare" Tag="Rare"/>
                                <ComboBoxItem Content="Normal" Tag="Normal"/>
                                <ComboBoxItem Content="Chatty" Tag="Chatty"/>
                            </ComboBox>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Watching Videos" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,0,6"/>
                            <ComboBox Grid.Row="3" Grid.Column="1" x:Name="FreqWatchingVideosCombo" Width="120" HorizontalAlignment="Left" Margin="0,0,0,6">
                                <ComboBoxItem Content="Silent" Tag="Silent"/>
                                <ComboBoxItem Content="Rare" Tag="Rare"/>
                                <ComboBoxItem Content="Normal" Tag="Normal"/>
                                <ComboBoxItem Content="Chatty" Tag="Chatty"/>
                            </ComboBox>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Studying / Coding" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,0,6"/>
                            <ComboBox Grid.Row="4" Grid.Column="1" x:Name="FreqStudyCodingCombo" Width="120" HorizontalAlignment="Left" Margin="0,0,0,6">
                                <ComboBoxItem Content="Silent" Tag="Silent"/>
                                <ComboBoxItem Content="Rare" Tag="Rare"/>
                                <ComboBoxItem Content="Normal" Tag="Normal"/>
                                <ComboBoxItem Content="Chatty" Tag="Chatty"/>
                            </ComboBox>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Default / Idle" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,0,6"/>
                            <ComboBox Grid.Row="5" Grid.Column="1" x:Name="FreqDefaultCombo" Width="120" HorizontalAlignment="Left" Margin="0,0,0,6">
                                <ComboBoxItem Content="Silent" Tag="Silent"/>
                                <ComboBoxItem Content="Rare" Tag="Rare"/>
                                <ComboBoxItem Content="Normal" Tag="Normal"/>
                                <ComboBoxItem Content="Chatty" Tag="Chatty"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Appearance Tab -->
            <TabItem Header="Appearance">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Appearance" FontWeight="Bold" FontSize="16"
                                   Foreground="{StaticResource PrimaryPinkBrush}" Margin="0,0,0,12"/>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Pet Size" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="SizeCombo" Width="140" HorizontalAlignment="Left">
                                <ComboBoxItem Content="Small (150)" Tag="150"/>
                                <ComboBoxItem Content="Normal (200)" Tag="200"/>
                                <ComboBoxItem Content="Large (250)" Tag="250"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Foreground="{StaticResource TextBrush}" Margin="0,0,0,4">
                                <Run Text="Opacity: "/><Run x:Name="OpacityLabel" Text="100%"/>
                            </TextBlock>
                            <Slider x:Name="OpacitySlider" Minimum="30" Maximum="100" Value="100"
                                    TickFrequency="5" IsSnapToTickEnabled="True"
                                    ValueChanged="OpacitySlider_ValueChanged"/>
                        </StackPanel>

                        <CheckBox x:Name="EnableGlitchCheck"
                                  Content="Enable digital glitch effect"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>

                        <Rectangle Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,8,0,12"/>

                        <CheckBox x:Name="EnableCatCheck"
                                  Content="Enable black cat companion"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>

                        <StackPanel Margin="20,0,0,10">
                            <TextBlock Text="Cat Name" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="CatNameBox" Width="150" HorizontalAlignment="Left"
                                     Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3"/>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,4,0,12"/>

                        <CheckBox x:Name="EnableAmbientPlanesCheck"
                                  Content="Enable ambient paper planes"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>

                        <StackPanel Margin="20,0,0,0">
                            <TextBlock Text="Plane frequency (minutes)" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="PlaneFreqCombo" Width="100" HorizontalAlignment="Left">
                                <ComboBoxItem Content="3" Tag="3"/>
                                <ComboBoxItem Content="5" Tag="5"/>
                                <ComboBoxItem Content="8" Tag="8"/>
                                <ComboBoxItem Content="10" Tag="10"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Music Tab -->
            <TabItem Header="Music">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Music" FontWeight="Bold" FontSize="16"
                                   Foreground="{StaticResource DigitalBlueBrush}" Margin="0,0,0,12"/>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Foreground="{StaticResource TextBrush}" Margin="0,0,0,4">
                                <Run Text="Music Folder "/><Run x:Name="SongCountLabel" Text="" Foreground="{StaticResource HolographicBlueBrush}"/>
                            </TextBlock>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="Browse..." Click="BrowseFolder_Click"
                                        Padding="12,4" Margin="8,0,0,0"/>
                                <TextBox x:Name="MusicFolderBox" IsReadOnly="True"
                                         Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                         BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3"/>
                            </DockPanel>
                            <TextBlock Text="Aemeath will play random songs from this folder when she sings."
                                       Foreground="#888" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- AI Tab -->
            <TabItem Header="AI">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <TextBlock Text="AI Chat" FontWeight="Bold" FontSize="16"
                                   Foreground="{StaticResource LemonYellowBrush}" Margin="0,0,0,12"/>

                        <!-- Provider selector -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="AI Provider" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="AiProviderCombo" Width="180" HorizontalAlignment="Left"
                                      SelectionChanged="AiProviderCombo_SelectionChanged">
                                <ComboBoxItem Content="Claude (Anthropic)" Tag="claude"/>
                                <ComboBoxItem Content="Gemini (Google)" Tag="gemini"/>
                                <ComboBoxItem Content="Claude Code Proxy" Tag="proxy"/>
                            </ComboBox>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,0,0,12"/>

                        <!-- Claude API Key -->
                        <StackPanel x:Name="ClaudeKeyPanel" Margin="0,0,0,10">
                            <TextBlock Text="Claude API Key" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" x:Name="ToggleKeyBtn"
                                        Content="Show" Click="ToggleApiKey_Click"
                                        Padding="8,4" Margin="8,0,0,0"/>
                                <PasswordBox x:Name="ApiKeyBox"
                                             Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                             BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3"/>
                            </DockPanel>
                            <TextBlock Text="Get your key at console.anthropic.com. Leave empty for offline mode."
                                       Foreground="#888" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Gemini API Key -->
                        <StackPanel x:Name="GeminiKeyPanel" Margin="0,0,0,10">
                            <TextBlock Text="Gemini API Key" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" x:Name="ToggleGeminiKeyBtn"
                                        Content="Show" Click="ToggleGeminiApiKey_Click"
                                        Padding="8,4" Margin="8,0,0,0"/>
                                <PasswordBox x:Name="GeminiApiKeyBox"
                                             Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                             BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3"/>
                            </DockPanel>
                            <TextBlock Text="Get your key at aistudio.google.com. Leave empty for offline mode."
                                       Foreground="#888" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Claude Code Proxy -->
                        <StackPanel x:Name="ProxyPanel" Margin="0,0,0,10">
                            <TextBlock Text="Proxy Base URL" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="ProxyBaseUrlBox"
                                     Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3"/>
                            <TextBlock Text="Default: http://localhost:42069. The proxy must be running."
                                       Foreground="#888" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>

                            <TextBlock Text="Model" Foreground="{StaticResource TextBrush}" Margin="0,8,0,4"/>
                            <ComboBox x:Name="ProxyModelCombo" Width="240" HorizontalAlignment="Left">
                                <ComboBoxItem Content="Claude Sonnet 4.5" Tag="claude-sonnet-4-5-20250929"/>
                                <ComboBoxItem Content="Claude Sonnet 4" Tag="claude-sonnet-4-20250514"/>
                                <ComboBoxItem Content="Claude Opus 4" Tag="claude-opus-4-20250514"/>
                                <ComboBoxItem Content="Claude Haiku 3.5" Tag="claude-3-5-haiku-20241022"/>
                            </ComboBox>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,4,0,12"/>

                        <CheckBox x:Name="EnableSingingBubblesCheck"
                                  Content="Show singing speech bubbles"
                                  Foreground="{StaticResource TextBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Voice Tab -->
            <TabItem Header="Voice">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <!-- Voice Input (STT) Section -->
                        <TextBlock Text="Voice Input (Speech-to-Text)" FontWeight="Bold" FontSize="16"
                                   Foreground="{StaticResource DigitalBlueBrush}" Margin="0,0,0,8"/>

                        <CheckBox x:Name="EnableVoiceInputCheck"
                                  Content="Enable voice input (push-to-talk)"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"
                                  Checked="VoiceInputToggled" Unchecked="VoiceInputToggled"/>

                        <StackPanel x:Name="VoiceInputPanel" Margin="20,0,0,0">
                            <TextBlock Text="STT Provider" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="SttProviderCombo" Width="180" HorizontalAlignment="Left"
                                      SelectionChanged="SttProviderCombo_SelectionChanged">
                                <ComboBoxItem Content="Whisper (OpenAI)" Tag="whisper"/>
                                <ComboBoxItem Content="Gemini (Google)" Tag="gemini"/>
                            </ComboBox>

                            <StackPanel x:Name="WhisperKeyPanel" Margin="0,8,0,0">
                                <TextBlock Text="Whisper (OpenAI) API Key" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                                <PasswordBox x:Name="WhisperApiKeyBox"
                                             Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                             BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3"/>
                                <TextBlock Text="Uses OpenAI Whisper API for transcription."
                                           Foreground="#888" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>

                            <TextBlock Text="When using Gemini STT, your Gemini API key from the AI tab is used."
                                       x:Name="GeminiSttNote" Foreground="#888" FontSize="11" Margin="0,8,0,0"
                                       TextWrapping="Wrap" Visibility="Collapsed"/>

                            <TextBlock Text="Language" Foreground="{StaticResource TextBrush}" Margin="0,12,0,4"/>
                            <ComboBox x:Name="SttLanguageCombo" Width="160" HorizontalAlignment="Left">
                                <ComboBoxItem Content="English" Tag="en"/>
                                <ComboBoxItem Content="Chinese" Tag="zh"/>
                                <ComboBoxItem Content="Japanese" Tag="ja"/>
                                <ComboBoxItem Content="Korean" Tag="ko"/>
                                <ComboBoxItem Content="Spanish" Tag="es"/>
                                <ComboBoxItem Content="French" Tag="fr"/>
                                <ComboBoxItem Content="German" Tag="de"/>
                            </ComboBox>

                            <CheckBox x:Name="VoiceIncludeScreenshotCheck"
                                      Content="Include screenshot with voice messages"
                                      Foreground="{StaticResource TextBrush}" Margin="0,12,0,4"/>
                            <TextBlock Text="Captures a screenshot and sends it along with the transcribed text to the AI."
                                       Foreground="#888" FontSize="11" Margin="20,0,0,0" TextWrapping="Wrap"/>

                            <TextBlock Text="Push-to-Talk Hotkey" Foreground="{StaticResource TextBrush}" Margin="0,12,0,4"/>
                            <TextBox x:Name="HotkeyBox" Width="160" HorizontalAlignment="Left"
                                     Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3"
                                     IsReadOnly="True" Cursor="Hand"
                                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                                     GotFocus="HotkeyBox_GotFocus"
                                     LostFocus="HotkeyBox_LostFocus"/>
                            <TextBlock Text="Click and press a key combo to set the hotkey."
                                       Foreground="#888" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,16,0,12"/>

                        <!-- TTS Section -->
                        <TextBlock Text="Text-to-Speech" FontWeight="Bold" FontSize="16"
                                   Foreground="{StaticResource GoldenAmberBrush}" Margin="0,0,0,8"/>

                        <CheckBox x:Name="EnableTtsCheck"
                                  Content="Enable text-to-speech"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"
                                  Checked="TtsToggled" Unchecked="TtsToggled"/>

                        <StackPanel x:Name="TtsPanel" Margin="20,0,0,10">
                            <TextBlock Text="Provider" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="TtsProviderCombo" Width="200" HorizontalAlignment="Left"
                                      SelectionChanged="TtsProviderCombo_SelectionChanged">
                                <ComboBoxItem Content="Edge TTS (Free)" Tag="edgetts"/>
                                <ComboBoxItem Content="GPT-SoVITS (Local)" Tag="gptsovits"/>
                                <ComboBoxItem Content="ElevenLabs (Cloud)" Tag="elevenlabs"/>
                                <ComboBoxItem Content="Fish Audio (Cloud)" Tag="fishaudio"/>
                                <ComboBoxItem Content="OpenAI TTS (Cloud)" Tag="openaitts"/>
                            </ComboBox>

                            <!-- Edge TTS settings -->
                            <StackPanel x:Name="EdgeTtsPanel" Margin="0,8,0,0">
                                <TextBlock Text="Voice Name" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                                <TextBox x:Name="EdgeTtsVoiceBox"
                                         Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                         BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3"/>
                                <TextBlock Text="e.g. en-US-AvaMultilingualNeural, zh-CN-XiaoxiaoNeural"
                                           Foreground="#888" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- GPT-SoVITS settings -->
                            <StackPanel x:Name="SovitsPanel" Margin="0,8,0,0">
                                <TextBlock Text="GPT-SoVITS Server URL" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                                <TextBox x:Name="SovitsUrlBox"
                                         Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                         BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3"/>
                                <TextBlock Text="URL of your local GPT-SoVITS server (e.g. http://localhost:9880)"
                                           Foreground="#888" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>

                                <Rectangle Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,12,0,8"/>
                                <TextBlock Text="Model Profiles" FontWeight="SemiBold" FontSize="13"
                                           Foreground="{StaticResource GoldenAmberBrush}" Margin="0,0,0,6"/>

                                <!-- Profile selector row -->
                                <DockPanel Margin="0,0,0,8">
                                    <Button DockPanel.Dock="Right" Content="Delete" Click="SovitsDeleteProfile_Click"
                                            Padding="8,4" Margin="4,0,0,0"/>
                                    <Button DockPanel.Dock="Right" Content="Add" Click="SovitsAddProfile_Click"
                                            Padding="8,4" Margin="4,0,0,0"/>
                                    <ComboBox x:Name="SovitsProfileCombo"
                                              SelectionChanged="SovitsProfileCombo_SelectionChanged"/>
                                </DockPanel>

                                <!-- Profile editor (hidden when no profile selected) -->
                                <StackPanel x:Name="SovitsProfileEditor" Margin="0,0,0,0">
                                    <TextBlock Text="Profile Name" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="SovitsProfileNameBox"
                                             Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                             BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3" Margin="0,0,0,8"/>

                                    <TextBlock Text="GPT Weights Path (.ckpt)" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                                    <DockPanel Margin="0,0,0,8">
                                        <Button DockPanel.Dock="Right" Content="..." Click="BrowseGptWeights_Click"
                                                Padding="8,4" Margin="4,0,0,0"/>
                                        <TextBox x:Name="SovitsGptWeightsBox"
                                                 Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                                 BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3"/>
                                    </DockPanel>

                                    <TextBlock Text="SoVITS Weights Path (.pth)" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                                    <DockPanel Margin="0,0,0,8">
                                        <Button DockPanel.Dock="Right" Content="..." Click="BrowseSovitsWeights_Click"
                                                Padding="8,4" Margin="4,0,0,0"/>
                                        <TextBox x:Name="SovitsSovitsWeightsBox"
                                                 Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                                 BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3"/>
                                    </DockPanel>

                                    <TextBlock Text="Reference Audio Path" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                                    <DockPanel Margin="0,0,0,8">
                                        <Button DockPanel.Dock="Right" Content="..." Click="BrowseRefAudio_Click"
                                                Padding="8,4" Margin="4,0,0,0"/>
                                        <TextBox x:Name="SovitsRefAudioBox"
                                                 Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                                 BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3"/>
                                    </DockPanel>

                                    <TextBlock Text="Prompt Text (transcription of reference audio)" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="SovitsPromptTextBox"
                                             Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                             BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3" Margin="0,0,0,8"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="Prompt Language" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                                            <ComboBox x:Name="SovitsPromptLangCombo" Width="130">
                                                <ComboBoxItem Content="Auto" Tag="auto"/>
                                                <ComboBoxItem Content="Chinese" Tag="zh"/>
                                                <ComboBoxItem Content="English" Tag="en"/>
                                                <ComboBoxItem Content="Japanese" Tag="ja"/>
                                                <ComboBoxItem Content="Korean" Tag="ko"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Text Language" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                                            <ComboBox x:Name="SovitsTextLangCombo" Width="130">
                                                <ComboBoxItem Content="Auto" Tag="auto"/>
                                                <ComboBoxItem Content="Chinese" Tag="zh"/>
                                                <ComboBoxItem Content="English" Tag="en"/>
                                                <ComboBoxItem Content="Japanese" Tag="ja"/>
                                                <ComboBoxItem Content="Korean" Tag="ko"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Foreground="{StaticResource TextBrush}" Margin="0,0,0,4">
                                        <Run Text="Speed: "/><Run x:Name="SovitsSpeedLabel" Text="1.0x"/>
                                    </TextBlock>
                                    <Slider x:Name="SovitsSpeedSlider" Minimum="50" Maximum="200" Value="100"
                                            TickFrequency="5" IsSnapToTickEnabled="True"
                                            ValueChanged="SovitsSpeedSlider_ValueChanged"/>

                                    <TextBlock Text="Paths must be accessible from the GPT-SoVITS server machine."
                                               Foreground="#888" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- ElevenLabs settings -->
                            <StackPanel x:Name="ElevenLabsPanel" Margin="0,8,0,0">
                                <TextBlock Text="ElevenLabs API Key" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                                <PasswordBox x:Name="ElevenLabsApiKeyBox"
                                             Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                             BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3"/>
                                <TextBlock Text="Voice ID" Foreground="{StaticResource TextBrush}" Margin="0,8,0,4"/>
                                <TextBox x:Name="ElevenLabsVoiceIdBox"
                                         Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                         BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3"/>
                                <TextBlock Text="Get your API key and voice IDs from elevenlabs.io"
                                           Foreground="#888" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Fish Audio settings -->
                            <StackPanel x:Name="FishAudioPanel" Margin="0,8,0,0">
                                <TextBlock Text="Fish Audio API Key" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                                <PasswordBox x:Name="FishAudioApiKeyBox"
                                             Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                             BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3"/>
                                <TextBlock Text="Model / Voice ID" Foreground="{StaticResource TextBrush}" Margin="0,8,0,4"/>
                                <TextBox x:Name="FishAudioModelIdBox"
                                         Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                         BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3"/>
                                <TextBlock Text="API Base URL" Foreground="{StaticResource TextBrush}" Margin="0,8,0,4"/>
                                <TextBox x:Name="FishAudioBaseUrlBox"
                                         Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                         BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3"/>
                                <TextBlock Text="Get your API key and create voice models at fish.audio"
                                           Foreground="#888" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- OpenAI TTS settings -->
                            <StackPanel x:Name="OpenAiTtsPanel" Margin="0,8,0,0">
                                <TextBlock Text="OpenAI API Key" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                                <PasswordBox x:Name="OpenAiTtsApiKeyBox"
                                             Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                             BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3"/>
                                <TextBlock Text="Model" Foreground="{StaticResource TextBrush}" Margin="0,8,0,4"/>
                                <ComboBox x:Name="OpenAiTtsModelCombo" Width="180" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="tts-1 (Standard)" Tag="tts-1"/>
                                    <ComboBoxItem Content="tts-1-hd (HD)" Tag="tts-1-hd"/>
                                    <ComboBoxItem Content="gpt-4o-mini-tts" Tag="gpt-4o-mini-tts"/>
                                </ComboBox>
                                <TextBlock Text="Voice" Foreground="{StaticResource TextBrush}" Margin="0,8,0,4"/>
                                <ComboBox x:Name="OpenAiTtsVoiceCombo" Width="160" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="alloy" Tag="alloy"/>
                                    <ComboBoxItem Content="ash" Tag="ash"/>
                                    <ComboBoxItem Content="coral" Tag="coral"/>
                                    <ComboBoxItem Content="echo" Tag="echo"/>
                                    <ComboBoxItem Content="fable" Tag="fable"/>
                                    <ComboBoxItem Content="onyx" Tag="onyx"/>
                                    <ComboBoxItem Content="nova" Tag="nova"/>
                                    <ComboBoxItem Content="sage" Tag="sage"/>
                                    <ComboBoxItem Content="shimmer" Tag="shimmer"/>
                                </ComboBox>
                                <TextBlock Foreground="{StaticResource TextBrush}" Margin="0,8,0,4">
                                    <Run Text="Speed: "/><Run x:Name="OpenAiTtsSpeedLabel" Text="1.0x"/>
                                </TextBlock>
                                <Slider x:Name="OpenAiTtsSpeedSlider" Minimum="25" Maximum="400" Value="100"
                                        TickFrequency="25" IsSnapToTickEnabled="True"
                                        ValueChanged="OpenAiTtsSpeedSlider_ValueChanged"/>
                                <TextBlock Text="Get your API key from platform.openai.com"
                                           Foreground="#888" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>

                            <TextBlock Foreground="{StaticResource TextBrush}" Margin="0,12,0,4">
                                <Run Text="Volume: "/><Run x:Name="TtsVolumeLabel" Text="70%"/>
                            </TextBlock>
                            <Slider x:Name="TtsVolumeSlider" Minimum="0" Maximum="100" Value="70"
                                    TickFrequency="5" IsSnapToTickEnabled="True"
                                    ValueChanged="TtsVolumeSlider_ValueChanged"/>

                            <CheckBox x:Name="SpeakChatResponsesCheck"
                                      Content="Speak chat responses"
                                      Foreground="{StaticResource TextBrush}" Margin="0,8,0,4"/>
                            <CheckBox x:Name="SpeakIdleChatterCheck"
                                      Content="Speak idle chatter"
                                      Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <CheckBox x:Name="AutoMuteFullscreenCheck"
                                      Content="Auto-mute during fullscreen"
                                      Foreground="{StaticResource TextBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Screen Awareness Tab -->
            <TabItem Header="Screen">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Screen Awareness" FontWeight="Bold" FontSize="16"
                                   Foreground="{StaticResource FusionFlameBrush}" Margin="0,0,0,4"/>
                        <Border Background="#3D2D2D" CornerRadius="6" Padding="10,6" Margin="0,0,0,12">
                            <TextBlock Text="&#x26A0; This feature captures screenshots of your screen. Use at your own discretion. All processing respects your privacy settings below."
                                       Foreground="#FFB0A0" FontSize="11" TextWrapping="Wrap"/>
                        </Border>

                        <CheckBox x:Name="EnableScreenCheck"
                                  Content="Enable screen awareness"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"
                                  Checked="ScreenAwarenessToggled" Unchecked="ScreenAwarenessToggled"/>

                        <StackPanel x:Name="ScreenAwarenessPanel" Margin="0,0,0,10">
                            <CheckBox x:Name="ShowScreenIndicatorCheck"
                                      Content="Show 'Aemeath can see' indicator"
                                      Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" IsChecked="True"/>

                            <!-- Privacy Layers -->
                            <Rectangle Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,0,0,8"/>
                            <TextBlock Text="Privacy Layers" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{StaticResource DigitalBlueBrush}" Margin="0,0,0,6"/>
                            <CheckBox x:Name="EnableProtectedWindowCheck"
                                      Content="Block when DRM-protected windows are visible"
                                      Foreground="{StaticResource TextBrush}" Margin="0,0,0,4" IsChecked="True"/>
                            <CheckBox x:Name="EnablePrivacyDownscaleCheck"
                                      Content="Downscale screenshots to destroy text legibility"
                                      Foreground="{StaticResource TextBrush}" Margin="0,0,0,4" IsChecked="True"
                                      Checked="PrivacyDownscaleToggled" Unchecked="PrivacyDownscaleToggled"/>
                            <StackPanel x:Name="DownscaleResolutionPanel" Orientation="Horizontal" Margin="20,0,0,4">
                                <TextBlock Text="Max width:" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox x:Name="DownscaleResolutionCombo" Width="100" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="320px" Tag="320"/>
                                    <ComboBoxItem Content="480px" Tag="480"/>
                                    <ComboBoxItem Content="640px" Tag="640"/>
                                </ComboBox>
                            </StackPanel>
                            <CheckBox x:Name="EnableResponsePiiScanCheck"
                                      Content="Scan AI responses for PII and discard if found"
                                      Foreground="{StaticResource TextBrush}" Margin="0,4,0,8" IsChecked="True"/>

                            <Rectangle Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,0,0,8"/>

                            <TextBlock Text="Vision provider" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="VisionProviderCombo" Width="200" HorizontalAlignment="Left" Margin="0,0,0,8"
                                      SelectionChanged="VisionProviderCombo_SelectionChanged">
                                <ComboBoxItem Content="Gemini Flash" Tag="gemini"/>
                                <ComboBoxItem Content="Claude" Tag="claude"/>
                                <ComboBoxItem Content="Ollama (Local)" Tag="ollama"/>
                                <ComboBoxItem Content="Local + Cloud Hybrid" Tag="local_hybrid"/>
                            </ComboBox>

                            <!-- Cloud API key (gemini/claude) -->
                            <StackPanel x:Name="VisionApiKeyPanel">
                                <TextBlock Text="Vision API key" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <PasswordBox x:Name="VisionApiKeyBox" Width="240" Padding="4,3"
                                                 Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                                 BorderBrush="{StaticResource SeparatorBrush}"/>
                                    <Button x:Name="ToggleVisionKeyBtn" Content="Show" Width="50" Margin="4,0,0,0"
                                            Click="ToggleVisionApiKey_Click"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Ollama settings (ollama / local_hybrid) -->
                            <StackPanel x:Name="OllamaPanel" Visibility="Collapsed">
                                <TextBlock Text="Ollama base URL" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                                <TextBox x:Name="OllamaBaseUrlBox" Width="280" HorizontalAlignment="Left"
                                         Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                         BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3" Margin="0,0,0,8"/>
                                <TextBlock Text="Ollama model name" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                                <TextBox x:Name="OllamaModelNameBox" Width="200" HorizontalAlignment="Left"
                                         Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                         BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3" Margin="0,0,0,8"/>
                            </StackPanel>

                            <!-- Hybrid cloud settings (local_hybrid only) -->
                            <StackPanel x:Name="HybridCloudPanel" Visibility="Collapsed">
                                <TextBlock Text="Hybrid cloud provider" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                                <ComboBox x:Name="HybridCloudProviderCombo" Width="160" HorizontalAlignment="Left" Margin="0,0,0,8">
                                    <ComboBoxItem Content="Gemini Flash" Tag="gemini"/>
                                    <ComboBoxItem Content="Claude" Tag="claude"/>
                                </ComboBox>
                                <TextBlock Text="Hybrid cloud API key" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                                <PasswordBox x:Name="HybridCloudApiKeyBox" Width="240" Padding="4,3"
                                             Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                             BorderBrush="{StaticResource SeparatorBrush}" Margin="0,0,0,8"/>
                            </StackPanel>

                            <TextBlock Text="Check interval (seconds)" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="ScreenIntervalCombo" Width="100" HorizontalAlignment="Left" Margin="0,0,0,8">
                                <ComboBoxItem Content="30" Tag="30"/>
                                <ComboBoxItem Content="60" Tag="60"/>
                                <ComboBoxItem Content="120" Tag="120"/>
                            </ComboBox>

                            <TextBlock Text="Monthly budget cap ($)" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="ScreenBudgetBox" Width="80" HorizontalAlignment="Left" Text="5.00"
                                     Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3" Margin="0,0,0,8"/>

                            <TextBlock Text="Analysis prompt" Foreground="{StaticResource TextBrush}" Margin="0,4,0,4"/>
                            <TextBox x:Name="ScreenPromptBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3" Margin="0,0,0,4"/>
                            <Button Content="Reset to default prompt" HorizontalAlignment="Left" Padding="8,3"
                                    Click="ResetScreenPrompt_Click" Margin="0,0,0,8"/>

                            <TextBlock Text="Blacklisted apps (one per line)" Foreground="{StaticResource TextBrush}" Margin="0,4,0,4"/>
                            <TextBox x:Name="ScreenBlacklistBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3" Margin="0,0,0,4"/>
                            <TextBlock Text="Format: process.exe or process.exe:*title pattern*"
                                       Foreground="#777" FontSize="10" Margin="0,0,0,8"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Backend Tab -->
            <TabItem Header="Backend">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <TextBlock Text="AI Backend" FontWeight="Bold" FontSize="16"
                                   Foreground="{StaticResource PrimaryPinkBrush}" Margin="0,0,0,12"/>
                        <TextBlock Text="The Python backend provides agentic AI with tools, RAG memory, and advanced capabilities."
                                   Foreground="#888" FontSize="11" Margin="0,0,0,12" TextWrapping="Wrap"/>

                        <CheckBox x:Name="EnableBackendCheck"
                                  Content="Enable AI Backend"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"
                                  Checked="BackendToggled" Unchecked="BackendToggled"/>

                        <StackPanel x:Name="BackendPanel">
                            <TextBlock Text="Mode" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="BackendModeCombo" Width="160" HorizontalAlignment="Left" Margin="0,0,0,8">
                                <ComboBoxItem Content="Auto-detect" Tag="auto"/>
                                <ComboBoxItem Content="Bundled (exe)" Tag="bundled"/>
                                <ComboBoxItem Content="Developer (python)" Tag="dev"/>
                            </ComboBox>

                            <TextBlock Text="Backend port" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="BackendPortBox" Width="80" HorizontalAlignment="Left"
                                     Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3" Margin="0,0,0,8"/>

                            <TextBlock Text="Internal API port" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="InternalPortBox" Width="80" HorizontalAlignment="Left"
                                     Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3" Margin="0,0,0,8"/>

                            <TextBlock Text="Python path (dev mode)" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <DockPanel Margin="0,0,0,8">
                                <Button DockPanel.Dock="Right" Content="Browse..." Click="BrowsePythonPath_Click"
                                        Padding="12,4" Margin="8,0,0,0"/>
                                <TextBox x:Name="PythonPathBox"
                                         Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                         BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3"/>
                            </DockPanel>

                            <Rectangle Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,4,0,12"/>
                            <TextBlock Text="API Keys (for backend tools)" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{StaticResource DigitalBlueBrush}" Margin="0,0,0,6"/>

                            <TextBlock Text="Tavily API key (web search)" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="TavilyApiKeyBox" Width="280" Padding="4,3"
                                         Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                         BorderBrush="{StaticResource SeparatorBrush}" Margin="0,0,0,8" HorizontalAlignment="Left"/>

                            <TextBlock Text="OpenWeatherMap API key" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="WeatherApiKeyBox" Width="280" Padding="4,3"
                                         Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                         BorderBrush="{StaticResource SeparatorBrush}" Margin="0,0,0,8" HorizontalAlignment="Left"/>

                            <Rectangle Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,4,0,12"/>

                            <TextBlock Text="Max crash retries" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="MaxRetriesBox" Width="60" HorizontalAlignment="Left"
                                     Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3" Margin="0,0,0,8"/>

                            <Rectangle Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,4,0,12"/>
                            <TextBlock Text="Status" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{StaticResource DigitalBlueBrush}" Margin="0,0,0,6"/>
                            <TextBlock x:Name="BackendStatusLabel" Text="Not started"
                                       Foreground="#888" FontSize="12" Margin="0,0,0,8"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- MCP Tab -->
            <TabItem Header="MCP">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <TextBlock Text="MCP (Model Context Protocol)" FontWeight="Bold" FontSize="16"
                                   Foreground="{StaticResource PrimaryPinkBrush}" Margin="0,0,0,12"/>
                        <TextBlock Text="Connect to external MCP servers for additional tools and expose Aemeath as an MCP server."
                                   Foreground="#888" FontSize="11" Margin="0,0,0,12" TextWrapping="Wrap"/>

                        <CheckBox x:Name="EnableMcpClientCheck"
                                  Content="Enable MCP client (connect to external servers)"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>

                        <CheckBox x:Name="EnableMcpServerCheck"
                                  Content="Expose Aemeath as MCP server"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>

                        <Rectangle Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,4,0,12"/>
                        <TextBlock Text="MCP Servers" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource DigitalBlueBrush}" Margin="0,0,0,6"/>
                        <TextBlock Text="Configure external MCP servers to connect to."
                                   Foreground="#888" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"/>

                        <ListBox x:Name="McpServerListBox" Height="100" Margin="0,0,0,8"
                                 Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                 BorderBrush="{StaticResource SeparatorBrush}"
                                 SelectionChanged="McpServerList_SelectionChanged"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="Add Server" Padding="12,4" Margin="0,0,8,0" Click="McpAddServer_Click"/>
                            <Button Content="Remove" Padding="12,4" Click="McpRemoveServer_Click"/>
                        </StackPanel>

                        <StackPanel x:Name="McpServerEditor" Visibility="Collapsed">
                            <TextBlock Text="Server name" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="McpServerNameBox" Width="240" HorizontalAlignment="Left"
                                     Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3" Margin="0,0,0,8"/>

                            <TextBlock Text="Command" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="McpServerCommandBox"
                                     Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3" Margin="0,0,0,8"/>

                            <TextBlock Text="Arguments" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="McpServerArgsBox"
                                     Background="{StaticResource MidDarkBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource SeparatorBrush}" Padding="4,3" Margin="0,0,0,8"/>

                            <TextBlock Text="Transport type" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="McpTransportCombo" Width="120" HorizontalAlignment="Left" Margin="0,0,0,8">
                                <ComboBoxItem Content="stdio" Tag="stdio"/>
                                <ComboBoxItem Content="SSE" Tag="sse"/>
                            </ComboBox>

                            <CheckBox x:Name="McpServerEnabledCheck"
                                      Content="Enabled"
                                      Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Save/Cancel buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,8,10,10">
            <Button Content="Cancel" Padding="20,6" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Save" Padding="20,6" Click="Save_Click"
                    Background="{StaticResource PrimaryPinkBrush}" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
