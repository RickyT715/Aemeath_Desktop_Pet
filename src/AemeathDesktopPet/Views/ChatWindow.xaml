<Window x:Class="AemeathDesktopPet.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chat with Aemeath"
        Width="380" Height="520"
        MinWidth="320" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource DarkSlateBrush}"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Chat bubble template -->
        <DataTemplate x:Key="MessageTemplate">
            <Grid Margin="8,4">
                <Border x:Name="Bubble" CornerRadius="10" Padding="10,6" MaxWidth="280"
                        HorizontalAlignment="Left">
                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="12.5"
                               Foreground="{StaticResource TextBrush}" LineHeight="18"/>
                </Border>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsUser}" Value="True">
                    <Setter TargetName="Bubble" Property="Background" Value="#3D2D4A"/>
                    <Setter TargetName="Bubble" Property="BorderBrush" Value="{StaticResource PrimaryPinkBrush}"/>
                    <Setter TargetName="Bubble" Property="BorderThickness" Value="1"/>
                    <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Right"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsAssistant}" Value="True">
                    <Setter TargetName="Bubble" Property="Background" Value="#2A2A4A"/>
                    <Setter TargetName="Bubble" Property="BorderBrush" Value="{StaticResource DigitalBlueBrush}"/>
                    <Setter TargetName="Bubble" Property="BorderThickness" Value="1"/>
                    <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Left"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Border Grid.Row="0" Background="#252540" MouseLeftButtonDown="TitleBar_MouseDown">
            <StackPanel Orientation="Horizontal" Margin="12,0">
                <TextBlock Text="&#x2605;" FontSize="14" Foreground="{StaticResource LemonYellowBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Chat with Aemeath" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Messages list -->
        <ListBox Grid.Row="1" x:Name="MessageList"
                 ItemsSource="{Binding Messages}"
                 ItemTemplate="{StaticResource MessageTemplate}"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 Padding="4">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Focusable" Value="False"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- Empty state -->
        <StackPanel Grid.Row="1" x:Name="EmptyState"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="Collapsed">
            <TextBlock Text="&#x2708;" FontSize="36" HorizontalAlignment="Center"
                       Foreground="{StaticResource DigitalBlueBrush}" Opacity="0.4"/>
            <TextBlock Text="Say hi to Aemeath~" FontSize="14" Margin="0,8,0,0"
                       Foreground="#666" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Status bar (Recording / Transcribing) -->
        <Border Grid.Row="2" x:Name="StatusBar" Background="#332233" Padding="8,4"
                Visibility="Collapsed">
            <TextBlock x:Name="StatusLabel" Text="" FontSize="11"
                       Foreground="{StaticResource PrimaryPinkBrush}" HorizontalAlignment="Center"/>
        </Border>

        <!-- Input area -->
        <Border Grid.Row="3" Background="#222238" Padding="8">
            <DockPanel>
                <!-- Send button -->
                <Button DockPanel.Dock="Right" x:Name="SendButton"
                        Content="&#x2708;" FontSize="16"
                        Width="40" Height="36" Margin="6,0,0,0"
                        Click="SendButton_Click"
                        IsEnabled="{Binding CanSend}"
                        Foreground="White" FontWeight="Bold"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="8" Padding="8,4">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="{StaticResource PrimaryPinkColor}" Offset="0"/>
                                                    <GradientStop Color="{StaticResource LemonYellowColor}" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Mic button (hold-to-record) -->
                <Button DockPanel.Dock="Right" x:Name="MicButton"
                        Content="&#x1F3A4;" FontSize="14"
                        Width="36" Height="36" Margin="4,0,0,0"
                        PreviewMouseLeftButtonDown="MicButton_MouseDown"
                        PreviewMouseLeftButtonUp="MicButton_MouseUp"
                        Foreground="White" Cursor="Hand"
                        ToolTip="Hold to record voice">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="MicBd" CornerRadius="8" Padding="4"
                                                Background="#3D3D5D">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Screenshot toggle -->
                <ToggleButton DockPanel.Dock="Right" x:Name="ScreenshotToggle"
                              Content="&#x1F4F7;" FontSize="13"
                              Width="36" Height="36" Margin="4,0,0,0"
                              IsChecked="{Binding IncludeScreenshot}"
                              ToolTip="Include screenshot with message"
                              Cursor="Hand">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="SsBd" CornerRadius="8" Padding="4"
                                                Background="#2A2A3A" BorderBrush="#3D3D5D" BorderThickness="1">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="SsBd" Property="Background" Value="#4D3D5D"/>
                                                <Setter TargetName="SsBd" Property="BorderBrush" Value="{StaticResource PrimaryPinkBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>

                <Border CornerRadius="8" Background="#2A2A3A" BorderBrush="#3D3D5D" BorderThickness="1"
                        Padding="2">
                    <TextBox x:Name="InputBox"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             Foreground="{StaticResource TextBrush}"
                             CaretBrush="{StaticResource DigitalBlueBrush}"
                             BorderThickness="0"
                             FontSize="12.5"
                             VerticalContentAlignment="Center"
                             Padding="8,6"
                             KeyDown="InputBox_KeyDown"
                             GotFocus="InputBox_GotFocus"
                             LostFocus="InputBox_LostFocus"/>
                </Border>
            </DockPanel>
        </Border>
    </Grid>
</Window>
