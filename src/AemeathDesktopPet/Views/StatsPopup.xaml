<Window x:Class="AemeathDesktopPet.Views.StatsPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="How's Aemeath?"
        Width="320" Height="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource DarkSlateBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="How's Aemeath?" FontWeight="Bold" FontSize="18"
                   Foreground="{StaticResource PrimaryPinkBrush}" Margin="0,0,0,16"/>

        <!-- Mood bar -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <DockPanel>
                <TextBlock Text="Mood" Foreground="{StaticResource TextBrush}" FontSize="13"/>
                <TextBlock x:Name="MoodValue" HorizontalAlignment="Right"
                           Foreground="{StaticResource PrimaryPinkBrush}" FontSize="13"/>
            </DockPanel>
            <Border Height="12" CornerRadius="6" Background="#2A2A3A" Margin="0,4,0,0">
                <Border x:Name="MoodBar" CornerRadius="6" HorizontalAlignment="Left">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{StaticResource PrimaryPinkColor}" Offset="0"/>
                            <GradientStop Color="{StaticResource FusionFlameColor}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Border>
        </StackPanel>

        <!-- Energy bar -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <DockPanel>
                <TextBlock Text="Energy" Foreground="{StaticResource TextBrush}" FontSize="13"/>
                <TextBlock x:Name="EnergyValue" HorizontalAlignment="Right"
                           Foreground="{StaticResource LemonYellowBrush}" FontSize="13"/>
            </DockPanel>
            <Border Height="12" CornerRadius="6" Background="#2A2A3A" Margin="0,4,0,0">
                <Border x:Name="EnergyBar" CornerRadius="6" HorizontalAlignment="Left">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{StaticResource LemonYellowColor}" Offset="0"/>
                            <GradientStop Color="{StaticResource GoldenAmberColor}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Border>
        </StackPanel>

        <!-- Affection bar -->
        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <DockPanel>
                <TextBlock Text="Affection" Foreground="{StaticResource TextBrush}" FontSize="13"/>
                <TextBlock x:Name="AffectionValue" HorizontalAlignment="Right"
                           Foreground="{StaticResource DigitalBlueBrush}" FontSize="13"/>
            </DockPanel>
            <Border Height="12" CornerRadius="6" Background="#2A2A3A" Margin="0,4,0,0">
                <Border x:Name="AffectionBar" CornerRadius="6" HorizontalAlignment="Left">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{StaticResource DigitalBlueColor}" Offset="0"/>
                            <GradientStop Color="{StaticResource HolographicBlueColor}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Border>
        </StackPanel>

        <!-- Separator -->
        <Rectangle Grid.Row="4" Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,8,0,12"/>

        <!-- Lifetime stats -->
        <StackPanel Grid.Row="5" Margin="0,0,0,12">
            <TextBlock Text="Lifetime Stats" FontWeight="SemiBold" FontSize="14"
                       Foreground="{StaticResource HolographicBlueBrush}" Margin="0,0,0,8"/>
            <TextBlock x:Name="DaysTogetherText" Foreground="{StaticResource TextBrush}" FontSize="12" Margin="0,2"/>
            <TextBlock x:Name="TotalChatsText" Foreground="{StaticResource TextBrush}" FontSize="12" Margin="0,2"/>
            <TextBlock x:Name="TotalPlanesText" Foreground="{StaticResource TextBrush}" FontSize="12" Margin="0,2"/>
            <TextBlock x:Name="TotalSongsText" Foreground="{StaticResource TextBrush}" FontSize="12" Margin="0,2"/>
            <TextBlock x:Name="TotalPetsText" Foreground="{StaticResource TextBrush}" FontSize="12" Margin="0,2"/>
        </StackPanel>

        <!-- Separator -->
        <Rectangle Grid.Row="6" Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,0,0,12"/>

        <!-- Aemeath's comment -->
        <Border Grid.Row="7" CornerRadius="8" Background="#2A2A4A" Padding="12,8"
                BorderBrush="{StaticResource DigitalBlueBrush}" BorderThickness="1">
            <TextBlock x:Name="AemeathComment" TextWrapping="Wrap" FontSize="12"
                       Foreground="{StaticResource TextBrush}" FontStyle="Italic"/>
        </Border>

        <!-- Close button -->
        <Button Grid.Row="8" Content="Close" Padding="20,6" HorizontalAlignment="Right"
                Margin="0,12,0,0" Click="Close_Click"
                Background="{StaticResource PrimaryPinkBrush}" Foreground="White" FontWeight="Bold"/>
    </Grid>
</Window>
