<Window x:Class="AemeathDesktopPet.Views.PetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AemeathDesktopPet.Views"
        Title="Aemeath"
        Width="200" Height="200"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="Manual">

    <Grid x:Name="RootGrid">
        <!-- Main pet sprite -->
        <Image x:Name="PetSprite"
               Width="{Binding SpriteSize}"
               Height="{Binding SpriteSize}"
               Stretch="Uniform"
               RenderOptions.BitmapScalingMode="HighQuality"
               Source="{Binding CurrentFrame}"
               Opacity="{Binding PetOpacity}"/>

        <!-- Glitch overlay (hidden by default, toggled by GlitchEffect) -->
        <Image x:Name="GlitchOverlay"
               Width="{Binding SpriteSize}"
               Height="{Binding SpriteSize}"
               Stretch="Uniform"
               RenderOptions.BitmapScalingMode="HighQuality"
               Visibility="Collapsed"
               IsHitTestVisible="False"
               Opacity="0.5"/>

        <!-- Particle canvas (transparent overlay, no hit testing) -->
        <Canvas x:Name="ParticleCanvas"
                IsHitTestVisible="False"
                Width="{Binding SpriteSize}"
                Height="{Binding SpriteSize}"
                Margin="-40,-80,0,0"/>

        <!-- Click-through indicator (small icon at top-right corner) -->
        <Border x:Name="ClickThroughIndicator"
                Visibility="Collapsed"
                IsHitTestVisible="False"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,4,4,0"
                Background="#88000000"
                CornerRadius="8"
                Padding="4,2">
            <TextBlock Text="&#x1F441;"
                       FontSize="10"
                       Foreground="#AAE0E0E0"
                       ToolTip="Click-through mode ON"/>
        </Border>

        <!-- Screen awareness indicator -->
        <Border x:Name="ScreenWatchBadge" Visibility="Collapsed"
                IsHitTestVisible="False"
                Background="#44000000" CornerRadius="8" Padding="6,2"
                HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4">
            <TextBlock Text="&#x1F441; Aemeath can see" FontSize="10" Foreground="#AAAAAAAA"
                       ToolTip="Screen awareness is active &#x2014; Aemeath periodically captures screenshots to comment on your activity"/>
        </Border>

        <!-- Speech bubble (anchored above pet) -->
        <views:SpeechBubble x:Name="SpeechBubbleControl"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Center"
                            Margin="0,-100,0,0"
                            Visibility="Collapsed"/>
    </Grid>
</Window>
